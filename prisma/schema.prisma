  @@index([userId])
}

// === Interviewer Groups ===

model InterviewerGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members InterviewerGroupMember[]
}

model InterviewerGroupMember {
  id        String           @id @default(cuid())
  groupId   String
  group     InterviewerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

// === Recruiting Agencies ===

model Agency {
  id            String   @id @default(cuid())
  name          String
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  website       String?
  feePercentage Decimal? @db.Decimal(5, 2) // e.g., 20.00 for 20%
  notes         String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recruiters AgencyRecruiter[]
  candidates AgencyCandidate[]
  jobs       AgencyJobAssignment[]
}

model AgencyRecruiter {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  email     String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidates AgencyCandidate[]

  @@index([agencyId])
  @@index([email])
}

// Track candidates submitted by agencies
model AgencyCandidate {
  id          String           @id @default(cuid())
  agencyId    String
  agency      Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  recruiterId String?
  recruiter   AgencyRecruiter? @relation(fields: [recruiterId], references: [id], onDelete: SetNull)
  candidateId String
  jobId       String
  status      String           @default("ACTIVE") // ACTIVE, HIRED, REJECTED
  submittedAt DateTime         @default(now())
  hiredAt     DateTime?
  fee         Decimal?         @db.Decimal(12, 2) // Actual fee charged
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([agencyId, candidateId, jobId])
  @@index([agencyId])
  @@index([recruiterId])
  @@index([candidateId])
  @@index([jobId])
}

// Agency assigned to specific jobs
model AgencyJobAssignment {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  jobId     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([agencyId, jobId])
  @@index([agencyId])
  @@index([jobId])
}

// === Approval Workflows ===

enum ApprovalWorkflowType {
  JOB_APPROVAL // Approval to start recruiting
  OFFER_APPROVAL // Approval to extend an offer
}

model ApprovalWorkflow {
  id          String               @id @default(cuid())
  type        ApprovalWorkflowType
  name        String
  description String?              @db.Text
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  steps ApprovalWorkflowStep[]
}

model ApprovalWorkflowStep {
  id          String           @id @default(cuid())
  workflowId  String
  workflow    ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  order       Int
  name        String // "Hiring Manager", "Finance", "Executive"
  approverIds String[] // User IDs or role-based: ["role:HQ_ADMIN", "user:123"]
  isRequired  Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([workflowId, order])
  @@index([workflowId])
}

// === Offer Templates (Documents) ===

model OfferTemplate {
  id          String   @id @default(cuid())
  name        String // "NYC/LA Tutor Offer Letter"
  description String?  @db.Text
  content     String   @db.Text // HTML content with merge tokens
  mergeTokens String[] // Available tokens: ["{{CANDIDATE_NAME}}", "{{SALARY}}"]
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// === Candidate Surveys ===

enum SurveyQuestionType {
  TEXT
  TEXTAREA
  SELECT
  MULTI_SELECT
  RATING // 1-5 star rating
  YES_NO
}

model CandidateSurvey {
  id           String   @id @default(cuid())
  name         String // "Post-Interview Survey", "Candidate Experience Survey"
  description  String?  @db.Text
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  // When to send: after_application, after_interview, after_rejection, after_hire
  triggerEvent String?  @default("after_application")
  delayHours   Int      @default(24) // Hours after trigger to send
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  questions SurveyQuestion[]
  responses SurveyResponse[]
}

model SurveyQuestion {
  id         String             @id @default(cuid())
  surveyId   String
  survey     CandidateSurvey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  text       String             @db.Text
  type       SurveyQuestionType @default(TEXT)
  options    String[] // For SELECT/MULTI_SELECT
  isRequired Boolean            @default(false)
  order      Int                @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  answers SurveyAnswer[]

  @@index([surveyId])
  @@index([order])
}

model SurveyResponse {
  id            String          @id @default(cuid())
  surveyId      String
  survey        CandidateSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  candidateId   String
  applicationId String?
  token         String          @unique @default(cuid()) // Anonymous access token
  submittedAt   DateTime?
  createdAt     DateTime        @default(now())

  answers SurveyAnswer[]

  @@index([surveyId])
  @@index([candidateId])
  @@index([token])
}

model SurveyAnswer {
  id         String         @id @default(cuid())
  responseId String
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value      String         @db.Text
  createdAt  DateTime       @default(now())

  @@unique([responseId, questionId])
  @@index([responseId])
  @@index([questionId])
}

// === Interview Kit System ===

// Interview Kit templates (per-job configuration)
model InterviewKit {
  id      String  @id @default(cuid())
  jobId   String
  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stageId String?
  stage   Stage?  @relation(fields: [stageId], references: [id], onDelete: SetNull)

  name             String // "Video Interview + Audition"
  type             InterviewType // PHONE_SCREEN, VIDEO_INTERVIEW, etc.
  duration         Int           @default(30) // minutes
  includesAudition Boolean       @default(false)
  order            Int           @default(0)

  prepItems  InterviewKitPrepItem[]
  categories InterviewKitCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([stageId])
}

// Interview prep talking points
model InterviewKitPrepItem {
  id    String       @id @default(cuid())
  kitId String
  kit   InterviewKit @relation(fields: [kitId], references: [id], onDelete: Cascade)

  title       String // "Storytelling Audition"
  description String? @db.Text // Rich text instructions
  duration    Int? // suggested minutes
  order       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kitId])
}

// Scorecard categories for interview kit
model InterviewKitCategory {
  id    String       @id @default(cuid())
  kitId String
  kit   InterviewKit @relation(fields: [kitId], references: [id], onDelete: Cascade)

  name  String // "Storytelling (Audition)"
  order Int    @default(0)

  attributes InterviewKitAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kitId])
}

// Individual scorecard attributes
model InterviewKitAttribute {
  id         String               @id @default(cuid())
  categoryId String
  category   InterviewKitCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name        String // "Enthusiasm & Energy"
  description String? // What to look for
  required    Boolean @default(true)
  order       Int     @default(0)

  ratings InterviewKitRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

// Recording storage
model InterviewRecording {
  id          String    @id @default(cuid())
  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  zoomMeetingId   String? // From Zoom webhook
  zoomRecordingId String? // Zoom's recording ID

  videoUrl String? // S3 URL for video (MP4)
  audioUrl String? // S3 URL for audio (M4A)
  duration Int? // seconds
  fileSize Int? // bytes

  status      RecordingStatus @default(PENDING)
  recordedAt  DateTime?
  processedAt DateTime?

  transcript InterviewTranscript?

  // Phase 6: Team Collaboration
  comments  InterviewComment[]
  bookmarks InterviewBookmark[]
  clips     InterviewClip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Transcript storage
model InterviewTranscript {
  id          String             @id @default(cuid())
  recordingId String             @unique
  recording   InterviewRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  fullText String @db.Text // Complete transcript
  segments Json // [{speaker, start, end, text}, ...]

  whisperJobId String? // For tracking async job

  createdAt DateTime @default(now())
}

// AI analysis and summary
model InterviewAISummary {
  id          String    @id @default(cuid())
  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  summary           String @db.Text // Overall summary
  attributeAnalysis Json // [{attributeId, evidence, suggestedRating}, ...]

  recommendation       String // STRONG_YES, YES, NO, STRONG_NO
  recommendationScore  Int // 0-100
  recommendationReason String @db.Text

  strengths         Json // ["Clear communicator", ...]
  concerns          Json // ["Limited experience with ages 3-5"]
  followUpQuestions Json // ["Ask about younger age groups"]

  createdAt DateTime @default(now())
}

// Completed scorecard (interviewer input)
model InterviewKitScorecard {
  id          String    @id @default(cuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  scorerId    String
  scorer      User      @relation("InterviewKitScorecards", fields: [scorerId], references: [id])

  keyTakeaways String? @db.Text // Rich text
  privateNotes String? @db.Text // Only visible to scorer

  overallRecommendation OverallRecommendation

  ratings InterviewKitRating[]

  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([interviewId])
  @@index([scorerId])
}

// Individual attribute ratings
model InterviewKitRating {
  id          String                @id @default(cuid())
  scorecardId String
  scorecard   InterviewKitScorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   InterviewKitAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  rating      Int // 1-5
  notes       String? // Optional notes for this attribute
  aiSuggested Int? // What AI suggested (for comparison)

  createdAt DateTime @default(now())

  @@index([scorecardId])
  @@index([attributeId])
}

// === Phase 6: Team Collaboration ===

// Timestamped comments on interview recordings
model InterviewComment {
  id          String             @id @default(cuid())
  recordingId String
  recording   InterviewRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  authorId    String
  author      User               @relation("InterviewComments", fields: [authorId], references: [id])

  timestamp  Float // seconds into the recording
  content    String  @db.Text
  isResolved Boolean @default(false)

  // Thread support for replies
  parentId String?
  parent   InterviewComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  InterviewComment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recordingId])
  @@index([authorId])
  @@index([timestamp])
}

// Bookmarks for key moments in recordings
model InterviewBookmark {
  id          String             @id @default(cuid())
  recordingId String
  recording   InterviewRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  authorId    String
  author      User               @relation("InterviewBookmarks", fields: [authorId], references: [id])

  timestamp Float // seconds into the recording
  label     String // "Great answer about teamwork"
  color     String? // Optional color coding (hex)

  createdAt DateTime @default(now())

  @@index([recordingId])
  @@index([authorId])
}

// Clips from recordings (internal team use)
model InterviewClip {
  id          String             @id @default(cuid())
  recordingId String
  recording   InterviewRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User               @relation("InterviewClips", fields: [createdById], references: [id])

  title     String // "Strong communication example"
  startTime Float // seconds
  endTime   Float // seconds

  shareToken String? @unique // For public sharing

  createdAt DateTime @default(now())

  @@index([recordingId])
  @@index([createdById])
}

// === Phase 7: Learning Foundation ===

// Pattern types for AI learning
enum PatternType {
  ANSWER_QUALITY // How they answer questions
  COMMUNICATION_STYLE // How they communicate
  ENTHUSIASM_SIGNAL // Signs of genuine interest
  RED_FLAG // Warning signs
  EXPERIENCE_CLAIM // How they describe experience
  QUESTION_ASKED // Questions they ask
}

// Track actual hiring outcomes for AI learning
model HiringOutcome {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Core outcome
  wasHired  Boolean
  hireDate  DateTime?
  startDate DateTime?

  // Retention tracking (updated over time)
  stillEmployedAt30Days  Boolean?
  stillEmployedAt90Days  Boolean?
  stillEmployedAt180Days Boolean?

  // Termination details
  terminatedAt      DateTime?
  terminationReason String? // VOLUNTARY, PERFORMANCE, NO_SHOW, etc.

  // Performance feedback (optional, from hiring manager)
  performanceRating Int? // 1-5
  performanceNotes  String? @db.Text

  // Rejection regret (did we pass on someone great?)
  rejectionRegret Boolean @default(false)
  regretNotes     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([wasHired])
  @@index([createdAt])
}

// Track AI recommendation accuracy feedback
model AIRecommendationFeedback {
  id          String    @id @default(cuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  // What AI recommended
  aiRecommendation String // STRONG_YES, YES, NO, STRONG_NO
  aiScore          Int // 0-100

  // What human decided
  humanRecommendation String? // STRONG_YES, YES, NO, STRONG_NO
  humanScore          Int? // 0-100 (from scorecard)

  // Explicit feedback
  wasAIHelpful  Boolean? // Did this save time / help decision?
  feedbackType  String? // AGREE, DISAGREE_TOO_HIGH, DISAGREE_TOO_LOW, PARTIALLY_AGREE
  feedbackNotes String?  @db.Text

  // Which specific AI observations were wrong?
  incorrectStrengths Json? // AI-identified strengths that weren't accurate
  missedStrengths    Json? // Strengths human noticed that AI missed
  incorrectConcerns  Json? // AI concerns that weren't valid
  missedConcerns     Json? // Concerns human noticed that AI missed

  createdAt DateTime @default(now())

  @@index([interviewId])
  @@index([feedbackType])
}

// === Phase 8: Pattern Extraction ===

// Learned patterns from successful hires
model InterviewPattern {
  id    String  @id @default(cuid())
  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  patternType PatternType
  pattern     String      @db.Text // The phrase, behavior, or response pattern
  context     String?     @db.Text // When this pattern matters

  // Scoring impact
  positiveSignal Boolean // Is this good or bad?
  weight         Float   @default(1.0)
  confidence     Float // How confident are we in this pattern? (0-1)

  // Evidence tracking
  exampleCount Int    @default(0)
  successRate  Float? // % of candidates with this pattern who were good hires

  // For human review
  isVerified   Boolean   @default(false)
  verifiedById String?
  verifiedBy   User?     @relation("VerifiedPatterns", fields: [verifiedById], references: [id])
  verifiedAt   DateTime?

  // Source tracking for audit
  sourceInterviewIds String[] // IDs of interviews this was extracted from

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([patternType])
  @@index([positiveSignal])
  @@index([isVerified])
  @@index([confidence])
}

// Question-answer examples for training and evaluation
model QuestionAnswerExample {
  id             String  @id @default(cuid())
  question       String  @db.Text
  questionIntent String? // What we're trying to learn from this question

  exampleAnswer String  @db.Text
  isGoodExample Boolean
  explanation   String? @db.Text // Why this is a good/bad answer

  // Quality metrics
  qualityScore Int? // 1-5 rating of answer quality

  // Source tracking
  sourceTranscriptId String?
  sourceInterviewId  String?

  // Categorization
  jobId       String?
  job         Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)
  attributeId String? // Which scorecard attribute this relates to

  // For review
  isVerified   Boolean   @default(false)
  verifiedById String?
  verifiedBy   User?     @relation("VerifiedQAExamples", fields: [verifiedById], references: [id])
  verifiedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([isGoodExample])
  @@index([isVerified])
}

// =============================================================================
// Phase 9: Async Text Screening
// =============================================================================

enum ScreeningType {
  TEXT_SMS // SMS-based screening
  TEXT_CHAT // In-app chat screening
  TEXT_EMAIL // Email-based screening
  VOICE_ASYNC // Record answer to question (future)
}

enum ScreeningStatus {
  PENDING // Not yet started
  IN_PROGRESS // Conversation active
  AWAITING_RESPONSE // Waiting for candidate reply
  COMPLETED // All questions answered
  EXPIRED // Candidate didn't respond in time
  HUMAN_TAKEOVER // Recruiter took over the conversation
}

enum ScreeningDecision {
  ADVANCE // Move to next stage
  SCHEDULE_CALL // Needs human phone screen
  REJECT // Not a fit
  HOLD // Needs more info/review
}

enum ScreeningQuestionType {
  OPEN_ENDED // Free text response
  MULTIPLE_CHOICE // Select from options
  YES_NO // Boolean response
  AVAILABILITY // Availability/schedule question
  SALARY_EXPECTATION // Compensation expectations
}

enum ScreeningMessageRole {
  AI // Message from AI
  CANDIDATE // Message from candidate
  SYSTEM // System notification
  RECRUITER // Human recruiter jumped in
}

// AI screening session for a candidate application
model AIScreeningSession {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type   ScreeningType
  status ScreeningStatus @default(PENDING)

  // SMS/Contact info (for TEXT_SMS type)
  candidatePhone String?

  // Configuration
  questionSetId String?
  questionSet   ScreeningQuestionSet? @relation(fields: [questionSetId], references: [id])

  // Timing
  startedAt      DateTime?
  completedAt    DateTime?
  expiresAt      DateTime?
  lastActivityAt DateTime?

  // Results
  aiScore           Int? // 0-100 overall score
  aiRecommendation  ScreeningDecision?
  aiNotes           String?            @db.Text
  knockoutTriggered Boolean            @default(false)
  knockoutReason    String?

  // Human review
  humanReviewerId String?
  humanReviewer   User?              @relation("ScreeningReviewer", fields: [humanReviewerId], references: [id])
  humanDecision   ScreeningDecision?
  humanNotes      String?            @db.Text
  reviewedAt      DateTime?

  // Messages in this session
  messages ScreeningMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([status])
  @@index([questionSetId])
  @@index([aiScore])
  @@index([candidatePhone])
}

// Reusable set of screening questions (can be job-specific or org-wide)
model ScreeningQuestionSet {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text

  // Optional job association (null = org-wide template)
  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // Whether this is the default set for the job
  isDefault Boolean @default(false)

  questions ScreeningQuestion[]
  sessions  AIScreeningSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([isDefault])
}

// Individual screening question
model ScreeningQuestion {
  id            String               @id @default(cuid())
  questionSetId String
  questionSet   ScreeningQuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)

  order        Int
  question     String                @db.Text
  questionType ScreeningQuestionType

  // For multiple choice questions
  options Json? // Array of option strings

  // Knockout configuration
  isKnockout      Boolean @default(false)
  knockoutAnswer  String? // Answer that triggers knockout
  knockoutMessage String? @db.Text // Message to send if knocked out

  // AI evaluation guidance
  evaluationPrompt   String? @db.Text // How AI should evaluate the answer
  minAcceptableScore Int? // 1-5, below this triggers concern

  // Follow-up logic
  conditionalFollowUp Boolean @default(false)
  followUpCondition   Json? // Condition for showing follow-up
  followUpQuestionId  String? // ID of follow-up question to ask

  createdAt DateTime @default(now())

  @@index([questionSetId])
  @@index([order])
}

// Individual message in a screening conversation
model ScreeningMessage {
  id        String             @id @default(cuid())
  sessionId String
  session   AIScreeningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role    ScreeningMessageRole
  content String               @db.Text

  // For tracking which question this answers
  questionId    String?
  questionOrder Int?

  // AI analysis of candidate response
  aiAnalysis String? @db.Text
  aiScore    Int? // 1-5 score for this answer

  // For voice messages (future)
  audioUrl   String?
  transcript String? @db.Text

  // Delivery tracking (for SMS/email)
  deliveredAt   DateTime?
  readAt        DateTime?
  deliveryError String?

  sentAt DateTime @default(now())

  @@index([sessionId])
  @@index([role])
  @@index([sentAt])
}
