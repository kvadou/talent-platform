# ===========================================
# Talent Platform - Environment Variables
# ===========================================
# Copy to .env.local and fill in values
# Items marked [REQUIRED] must be set to run locally
# Items marked [OPTIONAL] enable specific features

# [REQUIRED] Database — PostgreSQL with pgvector extension
DATABASE_URL=postgres://user:password@localhost:5432/talent_platform

# [REQUIRED] Clerk Authentication
# Create a free dev instance at https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# [REQUIRED] Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [REQUIRED] JWT Secret (for token encryption)
JWT_SECRET=your_jwt_secret_key_change_in_production

# [OPTIONAL] Email (Postmark)
# Without this, emails are logged to console instead of sent
POSTMARK_API_KEY=
POSTMARK_FROM_EMAIL=noreply@example.com

# [OPTIONAL] AWS S3 (resume storage)
# Without this, file uploads are disabled
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=talent-platform-resumes
AWS_REGION=us-east-1

# [OPTIONAL] OpenAI (AI scoring, embeddings, keyword expansion)
# Without this, AI features return mock/empty data
OPENAI_API_KEY=

# [OPTIONAL] Zoom (Server-to-Server OAuth for interview scheduling)
# Without these, Zoom integration returns mock meeting data
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# [OPTIONAL] Checkr (background checks)
# Without this, background check features return mock data
CHECKR_API_KEY=
CHECKR_API_URL=https://api.checkr-staging.com/v1

# [OPTIONAL] Dropbox Sign (e-signatures via HelloSign)
# Without this, e-signature features return mock data
DROPBOX_SIGN_API_KEY=
DROPBOX_SIGN_CLIENT_ID=

# [OPTIONAL] Internal E-Sign platform
# Without this, internal e-sign features return mock data
ESIGN_API_KEY=
ESIGN_BASE_URL=https://sign.example.com
ESIGN_WEBHOOK_SECRET=

# [OPTIONAL] Twilio (SMS notifications)
# Without these, SMS features are disabled
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# [OPTIONAL] Google Calendar (interview scheduling)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# [OPTIONAL] Sentry (error monitoring)
SENTRY_DSN=

# [OPTIONAL] Public Apply Page URL
APPLY_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# [OPTIONAL] External platform webhook integration
STT_WEBHOOK_URL=
STT_WEBHOOK_SECRET=

# [OPTIONAL] PostgreSQL Connection Pool Settings
# PG_POOL_MAX=35
# PG_POOL_MIN=8
# PG_CONNECTION_TIMEOUT_MS=3000
# PG_STATEMENT_TIMEOUT_MS=30000
